programa {
  funcao inicio() {
    real b1, b2, media

    escreva ("Insira a primeira nota: ")
      leia (b1)
    escreva ("Insira a segunda nota: ")
      leia (b2)
    
    media = (b1 + b2)/2
    
    limpa()
    escreva ("A média é ", media) 

  }
}

