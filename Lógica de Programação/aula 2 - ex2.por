programa {
  funcao inicio() {
    cadeia nome1, nome2, nome3 

    escreva("Insira o primeiro nome: ")
      leia(nome1)
    escreva("Insira o segundo nome: ")
      leia(nome2)
    escreva("Insira o terceiro nome: ")
      leia(nome3)

    limpa()
    escreva("Nomes: ", "\n", nome3, "\n", nome2, "\n", nome1)
  }

}
