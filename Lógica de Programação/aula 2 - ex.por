programa {
  funcao inicio() {
    real nota1, nota2, media

    escreva("Insira a primeira nota: ")
      leia(nota1)
    
    escreva("Insira a segunda nota ")
      leia(nota2)

    media = (nota1 + nota2)/2
      
    se (media >= 5) {escreva("Aprovado!")}
      senao {escreva("Reprovado")}
    
    
    
    }
}
